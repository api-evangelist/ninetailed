          "traits": {
            "plan": "enterprise",
            "industry": "fintech"
          },
          "location": {},
          "session": {},
          "stickyVariants": {}
        },
        {
          "id": "prof-user-002-def456",
          "stableId": "stable-user-002",
          "random": 0.2341,
          "audiences": ["audience-starter"],
          "traits": {
            "plan": "starter",
            "industry": "ecommerce"
          },
          "location": {},
          "session": {},
          "stickyVariants": {}
        }
      ],
      "error": null,
      "message": "ok"
    }
  }
}
